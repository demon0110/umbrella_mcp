# ===== REQUIRED: Cisco Umbrella / Secure Access API Credentials =====
# Generate these at: https://dashboard.umbrella.com → Admin → API Keys
# Click "Create" → name your key → select scopes (Reports, Deployments, etc.)
# Uses OAuth2 Client Credentials flow
#
# IMPORTANT: The API key is scoped to the organization you are logged into
# when you create it. For multi-tenant setups, create the key in the
# parent/management org and use CISCO_ORG_ID to target child orgs.
CISCO_CLIENT_ID="your-client-id-here"
CISCO_CLIENT_SECRET="your-client-secret-here"

# ===== ORGANIZATION ID (Multi-Tenant) =====
# Leave empty for single-org setups.
#
# For multi-tenant / MSP setups:
#   - Create your API key in the parent/management organization
#   - Set this to the child org ID you want to query
#   - Find org IDs at: Admin → Accounts, or from the dashboard URL
#     (e.g., https://dashboard.umbrella.com/o/1234567/)
#   - This value is sent as the X-Umbrella-OrgId header on every request
#
# To query multiple orgs, run separate MCP server instances with different
# CISCO_ORG_ID values. See README.md for examples.
CISCO_ORG_ID=""

# ===== API BASE URL =====
# Default: https://api.umbrella.com (standard Umbrella API)
# Alternative: https://api.sse.cisco.com (Cisco Secure Access branding)
# CISCO_BASE_URL="https://api.umbrella.com"

# Override auth endpoint (defaults to {base_url}/auth/v2/token)
# CISCO_AUTH_URL="https://api.umbrella.com/auth/v2/token"

# ===== CACHING CONFIGURATION =====
ENABLE_CACHING=true
CACHE_TTL_SECONDS=300
READ_ONLY_MODE=false

# ===== RESPONSE SIZE MANAGEMENT =====
ENABLE_FILE_CACHING=true
MAX_RESPONSE_TOKENS=5000
MAX_PER_PAGE=100
# RESPONSE_CACHE_DIR=/path/to/cache
